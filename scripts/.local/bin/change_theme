#!/bin/bash

# Define theme names
DARK_THEME='Gruvbox-Dark'
LIGHT_THEME='Gruvbox-Light'
DARK_ICON_THEME='Papirus-Dark'
LIGHT_ICON_THEME='Papirus-Light'

# Get current theme (remove quotes from gsettings output)
CURRENT_THEME=$(gsettings get org.gnome.desktop.interface gtk-theme | tr -d "'")

# Determine the opposite theme without changing anything yet
if [ "$CURRENT_THEME" = "$LIGHT_THEME" ]; then
    # If current theme is light, set THEME variable to dark
    THEME="$DARK_THEME"
    ICON_THEME="$DARK_ICON_THEME"
    gsettings set org.gnome.desktop.interface gtk-theme "$THEME"
    gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME"
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
else
    # If current theme is anything else, set THEME variable to light
    THEME="$LIGHT_THEME"
    ICON_THEME="$LIGHT_ICON_THEME"
    gsettings set org.gnome.desktop.interface gtk-theme "$THEME"
    gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME"
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-light'
fi

# Clear existing GTK4 config
rm -rf ~/.config/gtk-4.0
mkdir -p ~/.config/gtk-4.0

# Link the theme's GTK4 CSS files
if [ -d "/usr/share/themes/$THEME/gtk-4.0" ]; then
    ln -s /usr/share/themes/$THEME/gtk-4.0/* ~/.config/gtk-4.0/
fi

# Make sure themes are in ~/.themes for Flatpak (use copy, not symlinks)
mkdir -p ~/.themes
# Check if we need to update the themes
if [ ! -d "$HOME/.themes/$DARK_THEME" ] || [ "/usr/share/themes/$DARK_THEME" -nt "$HOME/.themes/$DARK_THEME" ]; then
    rm -rf "$HOME/.themes/$DARK_THEME"
    cp -r "/usr/share/themes/$DARK_THEME" "$HOME/.themes/"
fi
if [ ! -d "$HOME/.themes/$LIGHT_THEME" ] || [ "/usr/share/themes/$LIGHT_THEME" -nt "$HOME/.themes/$LIGHT_THEME" ]; then
    rm -rf "$HOME/.themes/$LIGHT_THEME"
    cp -r "/usr/share/themes/$LIGHT_THEME" "$HOME/.themes/"
fi

# Update Flatpak theme environment variable (safely)
flatpak override --user --env=GTK_THEME="$THEME" --env=ICON_THEME="$ICON_THEME"

# This might work for some GTK applications
dbus-send --session --dest=org.gtk.Settings --type=method_call /org/gtk/Settings org.gtk.Settings.ThemeChanged

notify-send "Theme Changed" "$THEME"
